DJANGO_SECRET_KEY=your-secret-key-here
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=kma-resilience-mriia.click,www.kma-resilience-mriia.click

POSTGRES_DB=ml_resilience
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_TO_SECURE_PASSWORD
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

OPENAI_API_KEY=your-openai-api-key-here
OPENAI_LLM_MODEL=gpt-4o-mini

EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@kma-resilience-mriia.click

APP_BASE_URL=https://kma-resilience-mriia.click
CONSENT_DOCUMENT_PATH=/opt/mriia/code/documents/consent.docx
RAW_SOURCES_DIR=/opt/mriia/code/raw_sources

# Production security settings
SECURE_SSL_REDIRECT=True
SECURE_PROXY_SSL_HEADER=HTTP_X_FORWARDED_PROTO,https
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
